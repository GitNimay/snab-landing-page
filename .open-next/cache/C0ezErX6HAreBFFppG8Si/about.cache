{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"},"segmentPaths":["/_tree","/_full","/about/__PAGE__","/about","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"manrope_aeb274eb-module__jkKXoG__variable pixelify_sans_c3cc5fe8-module__FXjWcW__variable font-sans geist_da832ead-module__aN_Ytq__variable\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/01d67e7cc17e7674-s.p.0m75r3fswdwux.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/a343f882a40d2cc9-s.p.1sj6eobyi31rd.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/about_hero.png\" as=\"image\"/><link rel=\"preload\" href=\"/about_team.png\" as=\"image\"/><link rel=\"preload\" href=\"/about_process.png\" as=\"image\"/><link rel=\"preload\" href=\"/about_portrait.png\" as=\"image\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/04aftq806-68o.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2eja5humdsdvl.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/1u8kf-cumb-f7.js\"/><script src=\"/_next/static/chunks/0ie0zj6s4jns8.js\" async=\"\"></script><script src=\"/_next/static/chunks/2nykiepra7i1k.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-37655peecauic.js\" async=\"\"></script><script src=\"/_next/static/chunks/158myu8e_yme3.js\" async=\"\"></script><script src=\"/_next/static/chunks/19i_c2papalpd.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>About Us | Snab Infotech</title><meta name=\"description\" content=\"Learn how Snab Infotech designs and builds AI products, intelligent software, and workflow automation.\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><main class=\"about-page\"><header class=\"topbar\" aria-label=\"Primary navigation\"><a class=\"brand\" href=\"/\" aria-label=\"Snab Infotech home\"><span class=\"brand-mark\" aria-hidden=\"true\"><span></span></span><span class=\"brand-name\">Snab Infotech</span></a><div class=\"mobile-menu-root\"><button class=\"menu-trigger\" type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"_R_8lfivb_\"><span class=\"menu-label\">Menu</span><span class=\"menu-icon\" aria-hidden=\"true\"><span></span><span></span></span></button></div></header><div class=\"about-page-side about-page-side-left\" aria-hidden=\"true\">SNAB INFOTECH<br/>ABOUT THE STUDIO</div><div class=\"about-page-side about-page-side-right\" aria-hidden=\"true\">01</div><article class=\"about-sheet\"><header class=\"about-sheet-header\"><a href=\"/\" aria-label=\"Return to the home page\"><span class=\"about-sheet-menu\" aria-hidden=\"true\"><span></span><span></span><span></span></span></a><span>ABOUT US</span><span>OUR APPROACH</span><span>WHAT WE BUILD</span><span>AI PRODUCT STUDIO</span><span>SNAB INFOTECH</span><a href=\"/contact\">CONTACT</a></header><section class=\"about-opening\" aria-labelledby=\"about-title\"><img class=\"about-blank about-opening-visual\" alt=\"Opening image placeholder\" src=\"/about_hero.png\"/><div class=\"about-opening-copy\"><p class=\"about-label\">SNAB INFOTECH</p><h1 id=\"about-title\">Building<br/>With AI</h1><p>We design and engineer AI-enabled products, internal tools, websites, desktop software, and automation systems for teams that need dependable production software.</p><span class=\"about-location\">PUNE, INDIA</span></div><div class=\"about-opening-note\"><p>Snab Infotech works across product strategy, interface design, full-stack engineering, AI integration, deployment, and ongoing iteration.</p></div><a class=\"about-opening-link\" href=\"/contact\"><span>START A PROJECT<br/>TALK WITH OUR TEAM</span><strong aria-hidden=\"true\">-&gt;</strong></a></section><section class=\"about-chapter-one\" aria-labelledby=\"chapter-one-title\"><div class=\"about-chapter-title\"><h2 id=\"chapter-one-title\">The AI Product<br/>Era Begins</h2><p>STRATEGY, SOFTWARE, AND AUTOMATION BUILT AS ONE SYSTEM.</p><span aria-hidden=\"true\">01</span></div><img class=\"about-blank about-chapter-one-visual\" alt=\"Team image placeholder\" src=\"/about_team.png\"/><div class=\"about-grid-copy\"><h3>WHAT WE BUILD</h3><p>AI products, workflow platforms, intelligent websites, desktop software, agents, RAG systems, and connected business tools.</p></div><div class=\"about-grid-heading\">ABOUT THE TEAM</div><div class=\"about-grid-heading\">ABOUT THE WORK</div><div class=\"about-grid-copy\"><h3>SNAB INFOTECH</h3><p>A compact engineering partner for founders, operators, and teams turning AI opportunities into shipped product work.</p></div></section><section class=\"about-chapter-two\" aria-labelledby=\"chapter-two-title\"><div class=\"about-statement\"><span aria-hidden=\"true\">02</span><p>THE SNAB STATEMENT</p><h2 id=\"chapter-two-title\">System First.<br/>AI Native.</h2></div><div class=\"about-name-rail\" aria-hidden=\"true\"><span>*</span><strong>SNAB INFOTECH</strong><em>AI PRODUCT STUDIO</em><span>*</span><strong>SNAB INFOTECH</strong><em>PRODUCT + ENGINEERING</em></div><div class=\"about-approach-title\"><h2>About Our<br/>Approach</h2><p>PRODUCT, ENGINEERING, AUTOMATION</p></div><div class=\"about-approach-media\"><div class=\"about-approach-copy\"><p>We start from the workflow, not the model. We map users, data, approvals, integrations, and failure states before choosing the AI layer.</p></div><img class=\"about-blank\" alt=\"Product process image placeholder\" src=\"/about_process.png\"/><img class=\"about-blank\" alt=\"Team portrait image placeholder\" src=\"/about_portrait.png\"/><div class=\"about-favorite-rail\" aria-hidden=\"true\">BUILD<br/>TEST<br/>LEARN<br/>SHIP<br/>BUILD<br/>TEST</div></div><div class=\"about-playbook\"><blockquote>We build the part of AI that has to survive real users, real data, and real operations.</blockquote><h2>Product<br/>Playbook</h2></div><div class=\"about-principles\"><ol><li>START WITH THE WORKFLOW</li><li>DESIGN FOR REAL USERS</li><li>CONNECT THE RIGHT DATA</li><li>BUILD THE COMPLETE SYSTEM</li><li>TEST IN PRODUCTION CONDITIONS</li><li>IMPROVE AFTER LAUNCH</li></ol><a href=\"/#services\">EXPLORE OUR SERVICES</a><a class=\"about-next-button\" href=\"/#services\" aria-label=\"Next page\">-&gt;</a></div></section><footer class=\"about-sheet-footer\"><a href=\"/\">LAST PAGE</a><span>SNAB INFOTECH / ABOUT US</span><a href=\"/#services\">NEXT PAGE</a></footer></article><footer class=\"site-footer\" aria-labelledby=\"footer-brand\"><div class=\"footer-grid-plane\" aria-hidden=\"true\"></div><div class=\"footer-top-rail\" aria-hidden=\"true\"></div><div class=\"footer-frame\"><div class=\"footer-left\"><div class=\"footer-brand-block\"><a class=\"footer-brand\" href=\"/#home\" aria-label=\"Snab Infotech home\"><span class=\"brand-mark footer-brand-mark\" aria-hidden=\"true\"><span></span></span><span id=\"footer-brand\" class=\"footer-brand-name\">Snab Infotech</span></a><p class=\"footer-tagline\">Build AI With<br/>Production Intelligence</p></div><nav class=\"footer-nav\" aria-label=\"Footer navigation\"><div class=\"footer-link-column\"><a href=\"/about\">Why Snab</a><a href=\"/#services\">Services</a><a href=\"/#projects\">Projects</a><a href=\"/#services\">Use Cases</a><a href=\"/contact\">Pricing</a><a href=\"/#faq\">FAQ&#x27;s</a></div><div class=\"footer-link-column\"><a href=\"/#services\">AI Products</a><a href=\"/#services\">Automation</a><a href=\"/contact\">Consulting</a></div><div class=\"footer-link-column\"><a href=\"#\">Privacy Policy</a><a href=\"#\">Terms &amp; Conditions</a></div></nav><div class=\"footer-badges\" aria-label=\"Core capabilities\"><span class=\"footer-badge\">AI</span><span class=\"footer-badge\">WEB</span><span class=\"footer-badge\">APP</span></div></div><div class=\"footer-right\"><div class=\"footer-socials\" aria-label=\"Social links\"><a class=\"footer-social footer-social-x\" href=\"#\">X / Twitter <span aria-hidden=\"true\">X</span></a><a class=\"footer-social\" href=\"#\">LinkedIn <span aria-hidden=\"true\">in</span></a></div><div class=\"footer-media-slot\" aria-label=\"Footer video placeholder\"><video class=\"footer-media-video\" src=\"/0DPAI75YDNDMgU2oIZR5R9KDWKA.mp4\" autoPlay=\"\" loop=\"\" muted=\"\" playsInline=\"\"></video></div><div class=\"footer-copyright\">© 2026 Snab Infotech</div></div></div><div class=\"footer-bottom-rail\" aria-hidden=\"true\"></div></footer></main><!--$--><!--/$--><script src=\"/_next/static/chunks/1u8kf-cumb-f7.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/158myu8e_yme3.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/158myu8e_yme3.js\\\"],\\\"default\\\"]\\n4:I[23758,[\\\"/_next/static/chunks/158myu8e_yme3.js\\\",\\\"/_next/static/chunks/19i_c2papalpd.js\\\"],\\\"MobileMenu\\\"]\\nf:I[68027,[\\\"/_next/static/chunks/158myu8e_yme3.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/04aftq806-68o.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/01d67e7cc17e7674-s.p.0m75r3fswdwux.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/a343f882a40d2cc9-s.p.1sj6eobyi31rd.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\\\",\\\"font\\\",{\\\"cros